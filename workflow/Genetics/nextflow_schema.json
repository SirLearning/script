{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "workflow/Genetics parameter schema",
  "description": "Parameter schema for the Genetics Nextflow pipeline.",
  "type": "object",
  "properties": {
    "home_dir": { "type": ["string", "null"] },
    "src_dir": { "type": ["string", "null"] },
    "user_dir": { "type": ["string", "null"] },
    "output_dir": { "type": ["string", "null"] },
    "mod": {
      "type": ["string", "null"],
      "description": "Pipeline mode: VCF/PLINK branch — v1_plink, test_thin, test_camp, test_common_thin; or wheat_* integrated modes."
    },
    "job": { "type": ["string", "null"] },
    "tool": { "type": ["string", "null"], "default": "plink" },
    "camp": { "type": ["string", "null"] },
    "chr": { "type": ["string", "null"] },
    "help": { "type": "boolean", "default": false, "description": "Print usage and exit when true." },
    "process_dir": { "type": ["string", "null"] },
    "mq_dir": {
      "type": "string",
      "default": "/data1/dazheng_tusr1/vmap4.VCF.v1/test_plink/process/abstract_mq_50_bams",
      "description": "Frozen site-MQ reference root (reference/, logs/). Partial task abstract_mq_50_bams only."
    },
    "mq_force_rerun": {
      "type": "boolean",
      "default": false,
      "description": "When true, rebuild MQ even if *.site_mq.ref.* already exists under mq_dir/reference."
    },
    "mq_chr_exclude": { "type": ["string", "null"] },
    "mq_bam_list_file": { "type": "string" },

    "wheat_table_input": { "type": ["string", "null"] },
    "wheat_gwas_genotype": { "type": ["string", "null"] },
    "wheat_gwas_phenotype": { "type": ["string", "null"] },
    "wheat_kgwas_kmer_matrix": { "type": ["string", "null"] },
    "wheat_kgwas_phenotype": { "type": ["string", "null"] },

    "wheat_snp_qc_maf": { "type": "number", "default": 0.05 },
    "wheat_snp_qc_max_missing": { "type": "number", "default": 0.1 },
    "wheat_snp_qc_min_qual": { "type": "number", "default": 30.0 },
    "wheat_pca_n_pcs": { "type": "integer", "default": 10 },
    "wheat_tsne_n_input_pcs": {
      "type": "integer",
      "default": 10,
      "description": "Leading PLINK PCs used as input to sklearn t-SNE in wheat_pca_tsne plots."
    },
    "wheat_tsne_max_iter": {
      "type": "integer",
      "default": 1000,
      "description": "Max iterations for sklearn TSNE (plot_population_structure)."
    },
    "wheat_tsne_random_state": {
      "type": "integer",
      "default": 42,
      "description": "Random seed for sklearn TSNE reproducibility."
    },
    "wheat_gcta_bin": { "type": "string", "default": "gcta64" },
    "wheat_gwas_tool": { "type": "string", "default": "plink2", "enum": ["plink2", "gcta"] },
    "wheat_afreq_input": { "type": ["string", "null"] },
    "wheat_vmiss_input": { "type": ["string", "null"] },
    "wheat_prune_in": { "type": ["string", "null"] },
    "wheat_plink_eigenvec": { "type": ["string", "null"] },
    "wheat_plink_eigenval": { "type": ["string", "null"] },
    "wheat_gwas_association": { "type": ["string", "null"] },
    "wheat_map_input": { "type": ["string", "null"] },
    "wheat_hapmap_input": { "type": ["string", "null"] },
    "wheat_kgwas_glm": { "type": ["string", "null"] },
    "wheat_plink_source_mod": {
      "type": ["string", "null"],
      "description": "Genotype process mod supplying merged *_test.plink2 (e.g. test_thin, test_common_thin) for wheat_* matrix export."
    },
    "wheat_integrated_mod": {
      "type": ["string", "null"],
      "description": "Wheat analytic mod for partial_task wheat_from_plink (e.g. wheat_pca_tsne); params.mod stays the PLINK source mod."
    },
    "partial_task": {
      "type": ["string", "null"],
      "description": "Partial rerun selector for subworkflows/local/entry/partial_router.nf: assess_plink, assess_vcf, ld_redraw, mac_stats, mac_dist_redraw, chr_counts, chr_compare, rebuild_lib_stats, wheat_from_plink."
    },
    "wheat_tagsnp_max_tags": { "type": "integer", "default": 1000 },
    "wheat_tagsnp_ld_threshold": { "type": "number", "default": 0.8 },
    "wheat_hapmap_window_size": { "type": "integer", "default": 100000 },
    "wheat_cnv_del_z": { "type": "number", "default": -2.0 },
    "wheat_cnv_dup_z": { "type": "number", "default": 2.0 },
    "wheat_gwas_trait": { "type": "string", "default": "Trait" },
    "wheat_kgwas_trait": { "type": "string", "default": "Trait" },

    "thin_rate": { "type": "number", "default": 0.001 },
    "hf_maf": { "type": "number", "default": 0.05 },
    "hf_geno": { "type": "number", "default": 0.2 },
    "hf_thin_rate": { "type": "number", "default": 0.005 },

    "ld_window_kb": { "type": "integer", "default": 5000 },
    "ld_decay_max_kb": { "type": "integer", "default": 5000 },
    "ld_decay_bin_kb": { "type": "integer", "default": 50 },

    "c_reset": { "type": "string", "description": "ANSI reset (terminal log styling)." },
    "c_dim": { "type": "string", "description": "ANSI dim (terminal log styling)." },
    "c_black": { "type": "string", "description": "ANSI black (terminal log styling)." },
    "c_green": { "type": "string", "description": "ANSI green (terminal log styling)." },
    "c_yellow": { "type": "string", "description": "ANSI yellow (terminal log styling)." },
    "c_red": { "type": "string", "description": "ANSI red (terminal log styling)." },
    "c_blue": { "type": "string", "description": "ANSI blue (terminal log styling)." },
    "c_purple": { "type": "string", "description": "ANSI magenta (terminal log styling)." },
    "c_cyan": { "type": "string", "description": "ANSI cyan (terminal log styling)." },
    "c_white": { "type": "string", "description": "ANSI white (terminal log styling)." }
  },
  "additionalProperties": true
}
