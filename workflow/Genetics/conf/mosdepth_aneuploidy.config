/*
 * Parallelism for mosdepth_aneuploidy_scan.nf (one task per summary file).
 * Pass alongside nextflow.config: -c .../conf/mosdepth_aneuploidy.config
 */
process {
    withName: 'mosdepth_aneuploidy_sample' {
        cpus = 1
        memory = '512 MB'
        maxForks = params.mosdepth_aneuploidy_max_forks ?: 16
    }
    withName: 'mosdepth_aneuploidy_collect' {
        cpus = 1
        memory = '8 GB'
    }
}
