params {
    // --- Required Parameters ---
    home_dir = null
    src_dir = null
    user_dir = null
    output_dir = null
    mod = null
    job = null
    server = null

    // --- Optional Parameters ---
    process_dir = null
    filter_dir = null
    assess_dir = null
    stats_dir = null
    kinship_dir = null
    ps_dir = null

    // --- Pipeline Control ---
    camp = null
    ing_dir = null
    vlib_dir = null
    gen_dir = null
    gen_tbm = null
    tiger_jar = "TIGER_F3_20251121.jar"
    workshop_jar = "Workshop.jar"
    samtools = "samtools"
    disc_min_MQ = 30
    disc_min_BQ = 20
    disc_min_DC = 2
    disc_min_DR = 0.2
    disc_max_DR = 3
    disc_HoR = 0.8
    disc_HeR = 0.35
    disc_TDR = 0.2
    blib_MAO = 2
    scan_min_MQ = 30
    scan_min_BQ = 20
    scan_error_rate = 0.05

    thin_rate = 0.001

    hf_maf = 0.05
    hf_geno = 0.2
    hf_thin_rate = 0.02
    hf_common_inter_thin_rate = 0.0014
    rare_inter_group_workers = 2
    rare_inter_plink_threads = 8

    pc_num = 10
    ld_window_kb = 5000
    ld_window = 999999
    ld_window_r2 = 0

    ld_decay_max_kb = 5000
    ld_decay_bin_kb = 50
    ld_decay_scatter_points = 200000
    ld_decay_chunksize = 2000000
    ld_decay_median_sample_per_bin = 20000
    ld_decay_random_seed = 42

    ld_crosschr_sample_rate = 0.01
    ld_crosschr_min_variants = 500
    ld_crosschr_window_kb = 1000000
    ld_crosschr_window = 99999999

    chr = null
    help = false

    // --- Site MQ reference (full-chr mpileup; partial_task abstract_mq_50_bams) ---
    // Frozen under vmap4 test_plink/process (one-off build; main pipeline never recomputes).
    mq_dir = "/data1/dazheng_tusr1/vmap4.VCF.v1/test_plink/process/abstract_mq_50_bams"
    mq_force_rerun = false
    mq_bam_list_file = "/data/home/tusr1/01projects/vmap4/05reliable.lib/01test/selected_bams_50.txt"
    mq_mpileup_max_depth = 250
    mq_pad_all_positions = true
    mq_ref_gzip = true
    mq_keep_sparse = false
    mq_decimal_places = 6
    // Parallel chromosomes during variant MQ tabix lookup (0 = auto: min(n_chr, CPU count)).
    mq_tabix_workers = 0
    // Comma-separated chr indices to skip (already published), e.g. "0,2,18,24,29,41,44"
    mq_chr_exclude = null
    // Mpileup-only: float MQ from INFO/I16 mean MAPQ; REF/ALT from mpileup (no bcftools call).

    // --- Population depth reference (full-chr TIGER; partial_task main_raw_popdepth) ---
    // Frozen under vmap4 test_plink/process/main_raw/variant (one-off build; test modes extract subset).
    popdep_dir = "/data1/dazheng_tusr1/vmap4.VCF.v1/test_plink/process/main_raw"
    popdep_force_rerun = false
    // TIGER jar/app for main_raw_popdepth (PopDep = position-major; PopDepFull = per-chr BAM scan; PopDepCrossChr = one BAM pass, all chr).
    popdep_tiger_jar = "TIGER_PD_20260619.jar"
    popdep_tiger_app = "PopDepCrossChr"
    // Override popdep publish root only (inputs still from popdep_dir/chrNNN.vcf.gz).
    // Must stay under /data1/.../vmap4.VCF.v1 — never under 01projects/vmap4 run dirs.
    popdep_publish_dir = null
    // PopDepCrossChr: concurrent samtools depth per taxon (I/O-saturated at 16 on vmap4 HDD).
    popdep_crosschr_threads = 16
    // TIGER_PD_20260619 relativeDepth roughly doubles JVM working set vs 20260616; 640G Xmx for full-genome CrossChr.
    popdep_crosschr_memory_gb = 640
    // PopDepCrossChr taxa submission order (-o): interleave | shuffle | sorted.
    popdep_crosschr_taxa_order = "interleave"
    // PopDepCrossChr checkpoint/resume (-k / -ci). null = single continuous pass (no checkpoint).
    popdep_crosschr_checkpoint_dir = null
    popdep_crosschr_checkpoint_interval = 500
    // PopDepFull only: concurrent chromosomes (I/O-saturated at 2 on vmap4 HDD).
    popdep_tiger_max_forks = 2
    // PopDepFull TIGER -e (samtools threads per chr task). Null → 32 for PopDepFull, 16 otherwise.
    popdep_tiger_threads = null
    // PopDepFull Java -Xmx (GB per chr task). Default 640 for PopDepFull (20260619 relativeDepth); 64 for other apps if overridden.
    popdep_tiger_memory_gb = 640
    // Parallel chromosomes during variant popdep lookup (0 = auto: min(n_chr, CPU count)).
    popdep_lookup_workers = 0
    // Comma-separated chr indices to skip (already published), e.g. "0,2,18"
    popdep_chr_exclude = null
    // Head-to-head / bench: explicit chr list (e.g. "2,10,36,1,43") instead of all ref chr or --chr.
    popdep_chr_list = null
    // Override taxa-BAM map (e.g. bench_assets/tb.N20.txt with a small taxa panel).
    popdep_taxa_bam_file = null
    // Bench: cap per-chr scan length (bp) for TIGER -c / chromosomeLength.txt (pair with truncated BAMs).
    popdep_bench_max_bp_per_chr = null
    // Bench: skip *.vcf.gz presence check under popdep_dir (PopDepFull input VCF is unused by TIGER depth).
    popdep_skip_vcf_check = false

    // --- Wheat integrated (table/matrix) analytics ---
    wheat_table_input = null
    wheat_gwas_genotype = null
    wheat_gwas_phenotype = null
    wheat_kgwas_kmer_matrix = null
    wheat_kgwas_phenotype = null
    wheat_snp_qc_maf = 0.05
    wheat_snp_qc_max_missing = 0.1
    wheat_snp_qc_min_qual = 30.0
    wheat_pca_n_pcs = 10
    wheat_tsne_n_input_pcs = 10
    wheat_tsne_max_iter = 1000
    wheat_tsne_random_state = 42
    wheat_plink_source_mod = null
    wheat_integrated_mod = null
    wheat_gcta_bin = 'gcta64'
    wheat_gwas_tool = 'plink2'
    wheat_afreq_input = null
    wheat_vmiss_input = null
    wheat_prune_in = null
    wheat_plink_eigenvec = null
    wheat_plink_eigenval = null
    wheat_gwas_association = null
    wheat_map_input = null
    wheat_hapmap_input = null
    wheat_kgwas_glm = null
    wheat_tagsnp_max_tags = 1000
    wheat_tagsnp_ld_threshold = 0.8
    wheat_hapmap_window_size = 100000
    wheat_cnv_del_z = -2.0
    wheat_cnv_dup_z = 2.0
    wheat_gwas_trait = 'Trait'
    wheat_kgwas_trait = 'Trait'

    maf = 0.05
    mac = 2
    min_alleles = 2
    max_alleles = 2
    max_missing = 0.05
    qual = 30
    hwe_pval = 1e-6

    // --- Colors ---
    c_reset  = "\033[0m";
    c_dim    = "\033[2m";
    c_black  = "\033[0;30m";
    c_green  = "\033[0;32m";
    c_yellow = "\033[0;33m";
    c_red    = "\033[0;31m";
    c_blue   = "\033[0;34m";
    c_purple = "\033[0;35m";
    c_cyan   = "\033[0;36m";
    c_white  = "\033[0;37m";
}

report {
    enabled = true
    file = 'pipeline_info/execution_report.html'
    overwrite = true
}

timeline {
    enabled = true
    file = 'pipeline_info/execution_timeline.html'
    overwrite = true
}

trace {
    enabled = true
    file = 'pipeline_info/execution_trace.txt'
    fields = 'task_id,hash,name,tag,status,exit,cpus,memory,attempt,duration,realtime,%cpu,%mem,rss,peak_rss,vmem,peak_vmem,read_bytes,write_bytes,submit,start,complete'
    overwrite = true
}

dag {
    enabled = true
    file = 'pipeline_info/pipeline_dag.svg'
    overwrite = true
}

cleanup = false
resume = true
conda.enabled = true
