params {
    // --- Required Parameters ---
    home_dir = null
    src_dir = null
    user_dir = null
    output_dir = null
    mod = null
    job = null
    server = null

    // --- Optional Parameters ---
    process_dir = null
    filter_dir = null
    assess_dir = null
    stats_dir = null
    kinship_dir = null
    ps_dir = null

    // --- Pipeline Control ---
    camp = null
    ing_dir = null
    vlib_dir = null
    gen_dir = null
    gen_tbm = null
    tiger_jar = "TIGER_F3_20251121.jar"
    workshop_jar = "Workshop.jar"
    samtools = "samtools"
    disc_min_MQ = 30
    disc_min_BQ = 20
    disc_min_DC = 2
    disc_min_DR = 0.2
    disc_max_DR = 3
    disc_HoR = 0.8
    disc_HeR = 0.35
    disc_TDR = 0.2
    blib_MAO = 2
    scan_min_MQ = 30
    scan_min_BQ = 20
    scan_error_rate = 0.05

    thin_rate = 0.001

    hf_maf = 0.05
    hf_geno = 0.2
    hf_thin_rate = 0.02

    pc_num = 10
    ld_window_kb = 5000
    ld_window = 999999
    ld_window_r2 = 0

    ld_decay_max_kb = 5000
    ld_decay_bin_kb = 50
    ld_decay_scatter_points = 200000
    ld_decay_chunksize = 2000000
    ld_decay_median_sample_per_bin = 20000
    ld_decay_random_seed = 42

    ld_crosschr_sample_rate = 0.01
    ld_crosschr_min_variants = 500
    ld_crosschr_window_kb = 1000000
    ld_crosschr_window = 99999999

    chr = null
    help = false

    // --- Site MQ reference (full-chr mpileup; partial_task abstract_mq_50_bams) ---
    // Legacy 01test 2_1_122798052.pos.txt was variant-site targets only (~29.8M/chr); not used here.
    mq_bam_list_file = "/data/home/tusr1/01projects/vmap4/05reliable.lib/01test/selected_bams_50.txt"
    mq_mpileup_max_depth = 250
    mq_pad_all_positions = true
    mq_ref_gzip = true
    mq_keep_sparse = false
    mq_decimal_places = 6
    // Mpileup-only: float MQ from INFO/I16 mean MAPQ; REF/ALT from mpileup (no bcftools call).

    // --- Wheat integrated (table/matrix) analytics ---
    wheat_table_input = null
    wheat_gwas_genotype = null
    wheat_gwas_phenotype = null
    wheat_kgwas_kmer_matrix = null
    wheat_kgwas_phenotype = null
    wheat_snp_qc_maf = 0.05
    wheat_snp_qc_max_missing = 0.1
    wheat_snp_qc_min_qual = 30.0
    wheat_pca_n_pcs = 10
    wheat_tsne_n_input_pcs = 10
    wheat_tsne_max_iter = 1000
    wheat_tsne_random_state = 42
    wheat_plink_source_mod = null
    wheat_integrated_mod = null
    wheat_gcta_bin = 'gcta64'
    wheat_gwas_tool = 'plink2'
    wheat_afreq_input = null
    wheat_vmiss_input = null
    wheat_prune_in = null
    wheat_plink_eigenvec = null
    wheat_plink_eigenval = null
    wheat_gwas_association = null
    wheat_map_input = null
    wheat_hapmap_input = null
    wheat_kgwas_glm = null
    wheat_tagsnp_max_tags = 1000
    wheat_tagsnp_ld_threshold = 0.8
    wheat_hapmap_window_size = 100000
    wheat_cnv_del_z = -2.0
    wheat_cnv_dup_z = 2.0
    wheat_gwas_trait = 'Trait'
    wheat_kgwas_trait = 'Trait'

    maf = 0.05
    mac = 2
    min_alleles = 2
    max_alleles = 2
    max_missing = 0.05
    qual = 30
    hwe_pval = 1e-6

    // --- Colors ---
    c_reset  = "\033[0m";
    c_dim    = "\033[2m";
    c_black  = "\033[0;30m";
    c_green  = "\033[0;32m";
    c_yellow = "\033[0;33m";
    c_red    = "\033[0;31m";
    c_blue   = "\033[0;34m";
    c_purple = "\033[0;35m";
    c_cyan   = "\033[0;36m";
    c_white  = "\033[0;37m";
}

report {
    enabled = true
    file = 'pipeline_info/execution_report.html'
    overwrite = true
}

timeline {
    enabled = true
    file = 'pipeline_info/execution_timeline.html'
    overwrite = true
}

trace {
    enabled = true
    file = 'pipeline_info/execution_trace.txt'
    fields = 'task_id,hash,name,tag,status,exit,cpus,memory,attempt,duration,realtime,%cpu,%mem,rss,peak_rss,vmem,peak_vmem,read_bytes,write_bytes,submit,start,complete'
    overwrite = true
}

dag {
    enabled = true
    file = 'pipeline_info/pipeline_dag.svg'
    overwrite = true
}

cleanup = false
resume = true
conda.enabled = true
