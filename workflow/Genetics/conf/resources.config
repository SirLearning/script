process {
    executor = 'local'
    cpus = 8
    memory = 64.GB
    errorStrategy = 'ignore'

    withLabel: cpus_16 {
        cpus = 16
        memory = 128.GB
    }

    withLabel: cpus_32 {
        cpus = 32
        memory = 256.GB
    }

    withLabel: cpus_64 {
        cpus = 64
        memory = 512.GB
    }

    withLabel: 'cpus_128' {
        cpus = 128
        memory = 1024.GB
    }

    withLabel: 'fastcall3_disc' {
        cpus = { params.chr ? 96 : 16 }
        memory = { (params.chr ? 256.GB : 96.GB) + (16.GB * task.attempt) }
        maxForks = 8
        errorStrategy = 'retry'
        maxRetries = 3
    }

    withLabel: 'fastcall3_blib' {
        cpus = { params.chr ? 96 : 16 }
        memory = { (params.chr ? 256.GB : 128.GB) + (8.GB * task.attempt) }
        errorStrategy = 'retry'
        maxRetries = 3
    }

    withLabel: 'fastcall3_scan' {
        cpus = { params.chr ? 96 : 64 }
        memory = { (params.chr ? 768.GB : 640.GB) + (128.GB * task.attempt) }
        errorStrategy = 'ignore'
    }

    withLabel: 'fastcall3_scan2' {
        cpus = { params.chr ? 32 : 96 }
        memory = { (params.chr ? 1408.GB : 1152.GB) + (128.GB * task.attempt) }
        errorStrategy = 'ignore'
    }

    withLabel: 'site_mq_bcftools' {
        // mpileup is I/O-bound (~1 CPU effective); prefer many low-cpu forks over few x32-thread tasks
        cpus = 4
        memory = 64.GB
        maxForks = 16
        errorStrategy = 'retry'
        maxRetries = 1
    }

    withLabel: 'popdep_tiger' {
        cpus = {
            params.popdep_tiger_threads != null
                ? "${params.popdep_tiger_threads}".toInteger()
                : (params.popdep_tiger_app == 'PopDepFull' ? 32 : 16)
        }
        memory = {
            params.popdep_tiger_memory_gb != null
                ? "${params.popdep_tiger_memory_gb}".toInteger().GB
                : (params.popdep_tiger_app == 'PopDepFull' ? 128.GB : 64.GB)
        }
        maxForks = params.popdep_tiger_max_forks
        errorStrategy = 'retry'
        maxRetries = 1
    }

    withLabel: 'popdep_tiger_crosschr' {
        cpus = params.popdep_crosschr_threads
        memory = { "${params.popdep_crosschr_memory_gb}".toInteger().GB }
        maxForks = 1
        errorStrategy = 'retry'
        maxRetries = 1
    }

    withLabel: 'popdep_bgz_tabix' {
        cpus = 8
        memory = 32.GB
        maxForks = 16
        errorStrategy = 'retry'
        maxRetries = 1
    }
}

executor {
    name = 'local'
    cpus = 128
    memory = 1792.GB
}
